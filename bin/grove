#!/usr/bin/env bash
# grove — spawn parallel Claude Code agents in git worktrees, grouped in cmux.
#
# Glue layer over worktrunk (`wt`) + cmux + Claude Code: `grove go <branch>
# <prompt>` creates a worktree and opens a cmux workspace running Claude on that
# prompt, filed under the repo's sidebar group (anchor = main checkout).
#
# https://github.com/jlopez/grove
set -euo pipefail

GROVE_VERSION="0.1.0"

# ---- output helpers ---------------------------------------------------------
if [ -t 2 ]; then
  _c_red=$'\033[31m'; _c_grn=$'\033[32m'; _c_ylw=$'\033[33m'
  _c_dim=$'\033[2m'; _c_bld=$'\033[1m'; _c_rst=$'\033[0m'
else
  _c_red=; _c_grn=; _c_ylw=; _c_dim=; _c_bld=; _c_rst=
fi
err()  { printf '%sgrove:%s %s\n' "$_c_red" "$_c_rst" "$*" >&2; }
info() { printf '%sgrove:%s %s\n' "$_c_grn" "$_c_rst" "$*" >&2; }
warn() { printf '%sgrove:%s %s\n' "$_c_ylw" "$_c_rst" "$*" >&2; }
die()  { err "$*"; exit 1; }

# ---- cmux binary discovery --------------------------------------------------
grove_cmux() {
  if [ -n "${GROVE_CMUX:-}" ]; then echo "$GROVE_CMUX"; return; fi
  if command -v cmux >/dev/null 2>&1; then command -v cmux; return; fi
  local app="/Applications/cmux.app/Contents/Resources/bin/cmux"
  [ -x "$app" ] && { echo "$app"; return; }
  return 1
}

# ---- repo identity ----------------------------------------------------------
# Sets: REPO (name) and REPO_PATH (main-checkout dir) — the group's stable
# identity, used for the cmux group name and the deterministic color; and
# WORKTREE_ROOT — the root of the worktree grove was invoked from, which is
# where .grove.json is read/written (so styling is committable on your branch
# and takes effect immediately, instead of dirtying the main checkout).
grove_repo_identity() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || die "not inside a git repository"
  local common
  common=$(git rev-parse --git-common-dir)
  # Absolutize (git may print a relative .git path) and strip trailing /.git
  common=$(cd "$common" && pwd)
  REPO_PATH=$(dirname "$common")
  REPO=$(basename "$REPO_PATH")
  WORKTREE_ROOT=$(git rev-parse --show-toplevel)
}

# ---- layered config store ---------------------------------------------------
# A single resolver all of grove reads through. Layers, low → high precedence:
#   1. ${XDG_CONFIG_HOME:-~/.config}/grove/config.json  — machine-wide defaults
#   2. <repo-root>/.grove.json                          — committed, repo-shared
#   3. <repo-root>/.grove.local.json                    — gitignored, personal
#   4. a per-keypath ENV_VAR                            — only where a caller opts in
# Files are deep-merged with jq's `*`, which recurses into objects and *replaces*
# arrays/scalars — exactly last-layer-wins per key. The env override (highest
# precedence) is applied per keypath at read time; there is no central registry —
# call sites pass the ENV_VAR they honor (see grove_config_get).
GROVE_CONFIG_JSON='{}'

# grove_config_load <repo-root> — merge the present config files (layers 1-3,
# rooted at <repo-root> for the repo-local files) into GROVE_CONFIG_JSON. Missing
# files are skipped; a file that isn't valid JSON is warned about and skipped
# (matching the defensive read it replaces), so one bad layer never breaks reads.
grove_config_load() {
  local root="$1" f
  local xdg="${XDG_CONFIG_HOME:-$HOME/.config}/grove/config.json"
  local present=()
  for f in "$xdg" "$root/.grove.json" "$root/.grove.local.json"; do
    [ -f "$f" ] || continue
    if jq -e . "$f" >/dev/null 2>&1; then
      present+=("$f")
    else
      warn "$f is not valid JSON — skipping that config layer"
    fi
  done
  if [ ${#present[@]} -eq 0 ]; then
    GROVE_CONFIG_JSON='{}'
  else
    GROVE_CONFIG_JSON=$(jq -s 'reduce .[] as $x ({}; . * $x)' "${present[@]}") \
      || GROVE_CONFIG_JSON='{}'
  fi
}

# grove_config_get <keypath> [ENV_VAR] — print the scalar at <keypath> from the
# loaded config. The keypath is dotted to descend into nested objects (e.g.
# "color", "agent.command"); a key may not itself contain a literal ".". If
# ENV_VAR is given AND set to a non-empty value it wins (the per-keypath
# override). Absent → "". Booleans/numbers are stringified; objects/arrays read
# as "" (use _get_array).
grove_config_get() {
  local keypath="$1" envvar="${2:-}"
  if [ -n "$envvar" ]; then
    local ev="${!envvar:-}"
    [ -n "$ev" ] && { printf '%s\n' "$ev"; return; }
  fi
  printf '%s' "$GROVE_CONFIG_JSON" | jq -r --arg kp "$keypath" '
    getpath($kp | split(".")) as $v
    | if   $v == null          then ""
      elif ($v|type)=="string" then $v
      elif ($v|type)=="object" or ($v|type)=="array" then ""
      else ($v|tostring) end'
}

# grove_config_get_array <keypath> — print each element of the array at <keypath>
# on its own line, for `mapfile -t`. Absent or non-array → nothing.
grove_config_get_array() {
  printf '%s' "$GROVE_CONFIG_JSON" | jq -r --arg kp "$1" '
    getpath($kp | split(".")) as $v
    | if ($v|type)=="array" then $v[] | tostring else empty end'
}

# grove_build_launch [prompt] — print the shell command cmux types into a new
# workspace, from the loaded config: agent.command (GROVE_COMMAND overrides;
# default claude) then the agent.args array, then the prompt if non-empty. Every
# token is %q-quoted so args/prompt survive the shell verbatim and the prompt
# lands as a single initial-prompt argument. Reads GROVE_CONFIG_JSON, so callers
# must grove_config_load first.
grove_build_launch() {
  local prompt="${1:-}" cmd launch a
  local args=()
  cmd=$(grove_config_get "agent.command" GROVE_COMMAND); cmd=${cmd:-claude}
  mapfile -t args < <(grove_config_get_array "agent.args")
  launch=$(printf '%q' "$cmd")
  for a in ${args[@]+"${args[@]}"}; do launch+=" $(printf '%q' "$a")"; done
  [ -n "$prompt" ] && launch+=" $(printf '%q' "$prompt")"
  printf '%s' "$launch"
}

# ---- group styling ----------------------------------------------------------
# 48-cell OKLCH palette: 24 hues × 2 lightness tiers (L≈0.74 / 0.62, C≈0.13),
# generated offline and gamut-fitted so every cell clears contrast on both light
# and dark sidebars. Perceptually even (OKLCH, not HSL) — only hue/lightness vary.
GROVE_PALETTE=(
  '#ED86A7' '#F18790' '#F28979' '#EE8F63' '#E6964F' '#DA9E3F' '#CBA63A' '#B7AF41'
  '#A0B751' '#86BD67' '#69C27E' '#47C496' '#1DC5AE' '#03C3C3' '#11C0D6' '#2EBBE8'
  '#52B5F4' '#70ADFB' '#8BA6FD' '#A39EF9' '#B897F0' '#CA91E3' '#D98CD2' '#E488BE'
  '#C46183' '#C8626D' '#C86556' '#C56A3E' '#BE7125' '#B37903' '#A48203' '#928A07'
  '#7C9128' '#629742' '#429C5A' '#029E72' '#0F9B89' '#169999' '#0897A9' '#1394BA'
  '#248FCC' '#4C88D3' '#6880D4' '#7F79D1' '#9372C8' '#A36CBC' '#B167AB' '#BC6398'
)

# grove_hash <string> -> short hex digest, stable across macOS/Linux.
grove_hash() {
  if command -v shasum >/dev/null 2>&1; then
    printf '%s' "$1" | shasum | cut -c1-8
  elif command -v sha1sum >/dev/null 2>&1; then
    printf '%s' "$1" | sha1sum | cut -c1-8
  else
    printf '%x' "$(printf '%s' "$1" | cksum | cut -d' ' -f1)"
  fi
}

# grove_color_for <repo-name> -> deterministic palette hex (same name → same hue).
grove_color_for() {
  local hexh idx
  hexh=$(grove_hash "$1")
  idx=$(( 16#$hexh % ${#GROVE_PALETTE[@]} ))
  printf '%s\n' "${GROVE_PALETTE[$idx]}"
}

# grove_random_color -> a random palette hex (backs `restyle --color random`,
# which stamps the *picked* hex into .grove.json — never the word "random").
grove_random_color() {
  printf '%s\n' "${GROVE_PALETTE[$((RANDOM % ${#GROVE_PALETTE[@]}))]}"
}

# grove_resolve_style <repo> <style-root> — sets STYLE_COLOR / STYLE_ICON.
#   STYLE_COLOR: "#RRGGBB" to apply, or "INHERIT" to clear (let byCwd/settings show).
#   STYLE_ICON:  SF Symbol to apply, or "" to CLEAR (revert to byCwd/default icon).
# Reads the layered config store rooted at <style-root> (see grove_config_load):
# color absent/"auto" → deterministic; "inherit" → clear; "#RRGGBB" → explicit;
# icon absent → clear. Both attributes fully reconcile: dropping a key reverts
# grove's imperative state for it, so persistent styling lives in the config.
grove_resolve_style() {
  local repo="$1" cval="" ival=""
  grove_config_load "$2"
  cval=$(grove_config_get "color")
  ival=$(grove_config_get "icon")
  case "$cval" in
    ''|auto)  STYLE_COLOR=$(grove_color_for "$repo") ;;
    inherit)  STYLE_COLOR="INHERIT" ;;
    '#'[0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f]) STYLE_COLOR="$cval" ;;
    *)        warn "config color '$cval' invalid (want #RRGGBB | auto | inherit) — using deterministic"
              STYLE_COLOR=$(grove_color_for "$repo") ;;
  esac
  STYLE_ICON="$ival"
}

# grove_apply_style <cmux> <group-ref> <repo> <repo-path> — reconcile cmux's
# imperative group style to .grove.json/deterministic. Idempotent; safe to re-run.
grove_apply_style() {
  local cmux="$1" g="$2"
  grove_resolve_style "$3" "$4"
  if [ "$STYLE_COLOR" = "INHERIT" ]; then
    CMUX_QUIET=1 "$cmux" workspace-group set-color "$g" >/dev/null 2>&1 || true
  else
    CMUX_QUIET=1 "$cmux" workspace-group set-color "$g" --hex "$STYLE_COLOR" >/dev/null 2>&1 || true
  fi
  if [ -n "$STYLE_ICON" ]; then
    CMUX_QUIET=1 "$cmux" workspace-group set-icon "$g" --symbol "$STYLE_ICON" >/dev/null 2>&1 || true
  else
    CMUX_QUIET=1 "$cmux" workspace-group set-icon "$g" >/dev/null 2>&1 || true
  fi
}

# grove_write_style <style-root> <color> <icon> — merge into
# <style-root>/.grove.json (created if absent), preserving any other keys.
# Empty color/icon = leave that key untouched; icon "none" = delete the key.
grove_write_style() {
  local f="$1/.grove.json" color="$2" icon="$3" base='{}' out
  [ -f "$f" ] && jq -e . "$f" >/dev/null 2>&1 && base=$(cat "$f")
  out=$(printf '%s' "$base" | jq --arg c "$color" --arg i "$icon" \
        '(if $c != "" then .color = $c else . end)
         | (if   $i == "none" then del(.icon)
            elif  $i != ""     then .icon = $i
            else  . end)') \
    || die "failed to update $f"
  printf '%s\n' "$out" > "$f"
  info "wrote $f"
}

# ---- worktree / cmux resolution ---------------------------------------------
# grove_worktree_path <branch> — print the worktree path worktrunk has for
# <branch>, or nothing if no worktree exists yet. Reads `wt list --format json`.
grove_worktree_path() {
  wt list --format json | jq -r --arg b "$1" \
    '.[] | select(.branch==$b) | .path' | head -1
}

# grove_title_in_group <groups-json> <workspaces-json> <repo> <branch> — exit 0
# iff some member workspace of the cmux group named <repo> has title == <branch>.
# Pure (only needs jq): the I/O lives in grove_branch_attached. Keys on the
# workspace title — grove sets `--name <branch>` at create, so title == branch —
# and is scoped to the repo group's members, so a same-named branch in another
# repo's group never false-matches. No matching group → no members → exit 1.
grove_title_in_group() {
  printf '%s' "$2" | jq -e \
    --argjson groups "$1" --arg repo "$3" --arg branch "$4" '
      [ $groups.groups[] | select(.name==$repo) ] as $g
      | ($g[0].member_workspace_refs // []) as $members
      | any(.workspaces[]; (.ref as $r | $members | index($r)) and .title == $branch)
    ' >/dev/null 2>&1
}

# grove_branch_attached <cmux> <repo> <branch> — exit 0 iff a cmux workspace in
# the repo's group is already attached to <branch> (see grove_title_in_group).
# Fetches the two cmux listings, then delegates the match to the pure helper.
grove_branch_attached() {
  local cmux="$1" repo="$2" branch="$3" groups workspaces
  groups=$(CMUX_QUIET=1 "$cmux" workspace-group list --json 2>/dev/null)   || return 1
  workspaces=$(CMUX_QUIET=1 "$cmux" workspace list --json 2>/dev/null)     || return 1
  grove_title_in_group "$groups" "$workspaces" "$repo" "$branch"
}

# =============================================================================
# grove go <branch> [prompt...]
# =============================================================================
grove_go() {
  [ $# -ge 1 ] || die "usage: grove go <branch> [prompt...]"
  local branch="$1"; shift
  local prompt="${*:-}"

  command -v wt >/dev/null 2>&1 || die "worktrunk (wt) not found — see 'grove doctor'"
  command -v jq >/dev/null 2>&1 || die "jq not found — see 'grove doctor'"
  local CMUX; CMUX=$(grove_cmux) || die "cmux CLI not found — see 'grove doctor'"

  grove_repo_identity

  # 1. Fail-fast cmux gate (before touching git): if a workspace in this repo's
  #    group is already attached to <branch>, stop — never spawn a duplicate.
  if grove_branch_attached "$CMUX" "$REPO" "$branch"; then
    die "a workspace is already attached to '$branch' — close it first, or pick another branch"
  fi

  # 2. Resolve-or-create the worktree (git). Three cases, by branch/worktree
  #    existence (see issue #2). Worktree exists → reuse its path, no `wt switch`;
  #    branch exists but no worktree → materialize it; neither → create both.
  #    `wt switch` fires worktrunk pre-start hooks (e.g. multi-account).
  local wtpath; wtpath=$(grove_worktree_path "$branch")
  if [ -n "$wtpath" ]; then
    info "reusing existing worktree for '$branch'"
  elif git -C "$REPO_PATH" show-ref --verify --quiet "refs/heads/$branch"; then
    info "branch '$branch' exists — materializing its worktree…"
    wt switch "$branch" --no-cd -y \
      || die "could not materialize worktree for existing branch '$branch'"
    wtpath=$(grove_worktree_path "$branch")
  else
    info "creating worktree for '$branch'…"
    wt switch -c "$branch" --no-cd -y \
      || die "worktree creation failed for '$branch'"
    wtpath=$(grove_worktree_path "$branch")
  fi
  [ -n "$wtpath" ] || die "could not resolve worktree path for '$branch'"

  # 3. Primary-checkout guard: never spawn into the group header (the repo's main
  #    checkout, which grove anchors each group at). Compare canonicalized paths.
  local canon_wt canon_repo
  canon_wt=$(cd "$wtpath" 2>/dev/null && pwd -P) || canon_wt="$wtpath"
  canon_repo=$(cd "$REPO_PATH" 2>/dev/null && pwd -P) || canon_repo="$REPO_PATH"
  [ "$canon_wt" != "$canon_repo" ] \
    || die "'$branch' is the repo's primary checkout — grove targets linked worktrees"

  # 4. Build the command cmux types into the new workspace's shell, from the
  #    layered config (agent.command + agent.args), then the prompt.
  grove_config_load "$WORKTREE_ROOT"
  local launch; launch=$(grove_build_launch "$prompt")

  # 5. Spawn the worktree workspace (inherits caller's cmux window via CMUX_* env).
  local ws
  ws=$(CMUX_QUIET=1 "$CMUX" workspace create \
        --cwd "$wtpath" --name "$branch" --command "$launch" --json \
        | jq -r '.workspace_ref')
  { [ -n "$ws" ] && [ "$ws" != "null" ]; } || die "cmux workspace create failed"

  # 6. File under the repo group; create it (anchor = main checkout) on first use.
  local gid
  gid=$(CMUX_QUIET=1 "$CMUX" workspace-group list --json \
        | jq -r --arg n "$REPO" 'first(.groups[] | select(.name==$n) | .ref) // empty')
  if [ -n "$gid" ]; then
    CMUX_QUIET=1 "$CMUX" workspace-group add --group "$gid" --workspace "$ws" >/dev/null
  else
    gid=$(CMUX_QUIET=1 "$CMUX" workspace-group create \
            --name "$REPO" --cwd "$REPO_PATH" --from "$ws" --json | jq -r '.group.ref')
  fi

  # 7. Reconcile group styling from this worktree's .grove.json (deterministic
  #    color by default).
  { [ -n "$gid" ] && [ "$gid" != "null" ]; } \
    && grove_apply_style "$CMUX" "$gid" "$REPO" "$WORKTREE_ROOT"

  CMUX_QUIET=1 "$CMUX" workspace select "$ws" >/dev/null 2>&1 || true
  info "spawned ${_c_bld}$ws${_c_rst} ($branch) under group '${_c_bld}$REPO${_c_rst}'"
  printf '%s\n' "$wtpath"
}

# =============================================================================
# grove restyle [--color #RRGGBB|auto|random|inherit] [--icon <sf-symbol>|none]
# Re-apply this repo's group style without spawning an agent. With --color/--icon
# it writes this worktree's .grove.json first (so hand-editing JSON is optional),
# then applies. --color random stamps a random palette hex; --icon none drops it.
# =============================================================================
grove_restyle() {
  local set_color="" set_icon="" color_set=0 icon_set=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --color) [ $# -ge 2 ] || die "grove restyle: --color needs a value (#RRGGBB | auto | random | inherit)"
               set_color="$2"; color_set=1; shift 2 ;;
      --icon)  [ $# -ge 2 ] || die "grove restyle: --icon needs an SF Symbol name (or 'none')"
               set_icon="$2"; icon_set=1; shift 2 ;;
      -h|--help) echo "usage: grove restyle [--color #RRGGBB|auto|random|inherit] [--icon <sf-symbol>|none]"; return 0 ;;
      *) die "grove restyle: unknown option '$1'" ;;
    esac
  done
  if [ "$color_set" = 1 ]; then
    case "$set_color" in
      auto|random|inherit|'#'[0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f]) ;;
      *) die "grove restyle: --color '$set_color' must be #RRGGBB, auto, random, or inherit" ;;
    esac
    # random resolves to a concrete palette hex now, so .grove.json stays stable.
    [ "$set_color" = random ] && set_color=$(grove_random_color)
  fi
  # an empty --icon means "drop the icon"; normalize to the delete sentinel.
  [ "$icon_set" = 1 ] && [ -z "$set_icon" ] && set_icon="none"
  # values to write: "" means "leave this key alone".
  [ "$color_set" = 1 ] || set_color=""
  [ "$icon_set"  = 1 ] || set_icon=""

  command -v jq >/dev/null 2>&1 || die "jq not found — see 'grove doctor'"
  local CMUX; CMUX=$(grove_cmux) || die "cmux CLI not found — see 'grove doctor'"
  grove_repo_identity

  { [ "$color_set" = 1 ] || [ "$icon_set" = 1 ]; } \
    && grove_write_style "$WORKTREE_ROOT" "$set_color" "$set_icon"

  local gid
  gid=$(CMUX_QUIET=1 "$CMUX" workspace-group list --json \
        | jq -r --arg n "$REPO" 'first(.groups[] | select(.name==$n) | .ref) // empty')
  [ -n "$gid" ] || { warn "no cmux group for '$REPO' yet — run 'grove go' first"; return 0; }

  grove_apply_style "$CMUX" "$gid" "$REPO" "$WORKTREE_ROOT"
  info "restyled group '${_c_bld}$REPO${_c_rst}'"
}

# =============================================================================
# grove doctor — verify dependencies and wiring
# =============================================================================
grove_doctor() {
  local ok=0
  _chk() { # name  test-cmd  hint
    if eval "$2" >/dev/null 2>&1; then
      printf '  %s✓%s %s\n' "$_c_grn" "$_c_rst" "$1"
    else
      printf '  %s✗%s %s %s(%s)%s\n' "$_c_red" "$_c_rst" "$1" "$_c_dim" "$3" "$_c_rst"
      ok=1
    fi
  }
  # Resolve the agent command the same way grove go does (config + GROVE_COMMAND),
  # loading the repo's config layers when run inside a worktree.
  local agent_cmd
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    && grove_config_load "$(git rev-parse --show-toplevel)"
  agent_cmd=$(grove_config_get "agent.command" GROVE_COMMAND); agent_cmd=${agent_cmd:-claude}

  printf '%sgrove doctor%s (v%s)\n' "$_c_bld" "$_c_rst" "$GROVE_VERSION"
  printf '\n%sRequired:%s\n' "$_c_bld" "$_c_rst"
  _chk "worktrunk (wt)" "command -v wt"                 "brew install worktrunk"
  _chk "cmux CLI"        "grove_cmux"                    "install cmux.app from cmux.dev"
  _chk "jq"              "command -v jq"                  "brew install jq"
  _chk "git"             "command -v git"                "xcode-select --install"
  _chk "agent ($agent_cmd)" "command -v $agent_cmd"      "install it (or set agent.command / GROVE_COMMAND)"
  printf '\n%sOptional:%s\n' "$_c_bld" "$_c_rst"
  _chk "direnv (multi-account)" "command -v direnv"       "brew install direnv"
  _chk "cmux Claude plugin"     "test -n \"\$(wt config show 2>/dev/null | grep -i 'Plugin installed')\"" \
                                "wt config plugins claude install"
  _chk "wt go alias"            "wt config show 2>/dev/null | grep -qE '^\s*go\s*='" \
                                "grove init"
  [ -n "${CMUX_WORKSPACE_ID:-}" ] \
    && printf '\n%s✓ running inside cmux%s (window targeting works)\n' "$_c_grn" "$_c_rst" \
    || printf '\n%s!%s not inside a cmux workspace — %sgrove go%s targets cmux best when run from a cmux tab\n' \
         "$_c_ylw" "$_c_rst" "$_c_bld" "$_c_rst"
  return $ok
}

# =============================================================================
# grove init [--with-multi-account] — optional wiring
# =============================================================================
GROVE_CONFIG="${WORKTRUNK_CONFIG:-$HOME/.config/worktrunk/config.toml}"

grove_init() {
  local want_multi=0
  for a in "$@"; do
    case "$a" in
      --with-multi-account) want_multi=1 ;;
      -h|--help) echo "usage: grove init [--with-multi-account]"; return 0 ;;
      *) die "grove init: unknown option '$a'" ;;
    esac
  done

  command -v wt >/dev/null 2>&1 || die "worktrunk (wt) required first — see 'grove doctor'"
  mkdir -p "$(dirname "$GROVE_CONFIG")"
  [ -f "$GROVE_CONFIG" ] || { warn "no worktrunk config; creating one"; wt config create >/dev/null 2>&1 || true; }
  touch "$GROVE_CONFIG"

  # 1. cmux Claude plugin (activity markers + statusline source).
  if wt config show 2>/dev/null | grep -qi "Plugin installed"; then
    info "cmux Claude plugin already installed"
  else
    info "installing cmux Claude plugin…"
    if wt config plugins claude install --yes >/dev/null 2>&1; then
      info "  done"
    else
      warn "  skipped (install manually: wt config plugins claude install)"
    fi
  fi

  # 2. wt go alias (sugar for `grove go`).
  if grep -qE '^\s*go\s*=' "$GROVE_CONFIG"; then
    info "'wt go' alias already present"
  else
    info "adding 'wt go' alias to $GROVE_CONFIG"
    if grep -qE '^\s*\[aliases\]' "$GROVE_CONFIG"; then
      # append under existing [aliases]
      awk '1; /^\[aliases\]/ && !done { print "go = \"grove go {{ args[0] }} {{ args[1:] | join('"'"' '"'"') }}\""; done=1 }' \
        "$GROVE_CONFIG" > "$GROVE_CONFIG.tmp" && mv "$GROVE_CONFIG.tmp" "$GROVE_CONFIG"
    else
      printf '\n[aliases]\ngo = "grove go {{ args[0] }} {{ args[1:] | join('"'"' '"'"') }}"\n' >> "$GROVE_CONFIG"
    fi
  fi

  # 3. Optional multi-account direnv hook.
  if [ "$want_multi" = 1 ]; then
    if grep -qE '^\s*gh-account\s*=' "$GROVE_CONFIG"; then
      info "multi-account hook already present"
    elif ! command -v direnv >/dev/null 2>&1; then
      warn "multi-account requested but direnv not found; skipping (brew install direnv)"
    else
      info "adding multi-account pre-start hook"
      cat >> "$GROVE_CONFIG" <<'TOML'

# grove: per-worktree GH_CONFIG_DIR inherited from the main checkout's direnv.
[pre-start]
gh-account = """
ghdir=$(direnv exec {{ primary_worktree_path }} sh -c 'printf %s "$GH_CONFIG_DIR"')
if [ -n "$ghdir" ]; then
  printf 'export GH_CONFIG_DIR=%s\n' "$ghdir" > {{ worktree_path }}/.envrc
  direnv allow {{ worktree_path }}
fi
"""
TOML
    fi
  fi

  # 4. Gitignore the personal config override, if run inside a repo. The
  #    committed .grove.json is repo identity; .grove.local.json is per-machine.
  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    local top gi
    top=$(git rev-parse --show-toplevel)
    gi="$top/.gitignore"
    if git -C "$top" check-ignore -q .grove.local.json; then
      info ".grove.local.json already gitignored"
    else
      info "adding .grove.local.json to ${gi#"$top"/}"
      # preserve a final newline: if the file lacks a trailing one, add it first
      [ -s "$gi" ] && [ -n "$(tail -c1 "$gi")" ] && printf '\n' >> "$gi"
      printf '%s\n' ".grove.local.json" >> "$gi"
    fi
  fi

  info "init complete — try: ${_c_bld}grove go feature/test draft a hello-world${_c_rst}"
  [ "$want_multi" = 1 ] || info "multi-account direnv inheritance available via ${_c_bld}grove init --with-multi-account${_c_rst}"
}

# ---- dispatch ---------------------------------------------------------------
grove_usage() {
  cat <<EOF
${_c_bld}grove${_c_rst} v$GROVE_VERSION — parallel Claude agents in worktrees, grouped in cmux

${_c_bld}Usage:${_c_rst}
  grove go <branch> [prompt...]   Create a worktree + spawn a cmux Claude agent
  grove restyle [--color C] [--icon S]   Re-apply this repo's group color/icon
  grove init [--with-multi-account]   Optional wiring (alias, cmux plugin, direnv)
  grove doctor                    Check dependencies and wiring
  grove version

${_c_bld}Config (layered, low → high precedence):${_c_rst}
  \${XDG_CONFIG_HOME:-~/.config}/grove/config.json   machine-wide defaults
  <repo-root>/.grove.json                           committed, repo-shared
  <repo-root>/.grove.local.json                     gitignored, personal
  Files deep-merge (last layer wins per key). Repo files are read from the
  worktree you run grove in, so styling is committable on your branch.

${_c_bld}Per-repo styling${_c_rst} (any of the layers above):
  color: #RRGGBB | "auto" (deterministic from repo name) | "inherit" (clear)
  icon:  an SF Symbol name (e.g. "leaf.fill"); omit to clear (use byCwd/default)
  restyle --color random stamps a random palette color; --icon none drops the icon

${_c_bld}Per-repo agent${_c_rst} (any of the layers above):
  agent.command  executable to launch (default: claude; env GROVE_COMMAND wins)
  agent.args     array of argv tokens passed before the prompt (default: none)

${_c_bld}Env:${_c_rst}
  GROVE_COMMAND command to launch (overrides agent.command; default: claude)
  GROVE_CMUX    path to the cmux CLI (default: auto-detect)
EOF
}

main() {
  local cmd="${1:-}"; shift || true
  case "$cmd" in
    go)            grove_go "$@" ;;
    restyle)       grove_restyle "$@" ;;
    init)          grove_init "$@" ;;
    doctor)        grove_doctor "$@" ;;
    version|--version|-V) echo "grove v$GROVE_VERSION" ;;
    help|--help|-h|"") grove_usage ;;
    *) err "unknown command '$cmd'"; grove_usage; exit 1 ;;
  esac
}

# Run only when executed, not when sourced (tests source for unit checks).
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
  main "$@"
fi
